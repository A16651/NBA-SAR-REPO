    label: "AI Output Validation"
}

####################################################
# Audit Layer
####################################################

audit: {
    label: "Audit & Compliance"

    style: {
        fill: "#EBDEF0"
        stroke: "#6C3483"
    }
}

audit_log: {
    label: "Immutable Audit Log"
}

sar_version: {
    label: "SAR Version History"
}

