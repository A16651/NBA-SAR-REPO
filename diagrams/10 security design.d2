    label: "End-to-End Traceability"
}

####################################################
# Security
####################################################

security: {
    label: "Security Controls"

    style: {
        fill: "#FADBD8"
        stroke: "#922B21"
    }
}

transport: {
    label: "TLS Encryption"
}

storage: {
    label: "Encrypted Storage"
}

####################################################
# Governance Flow
####################################################

identity -> authentication

authentication -> authorization

authorization -> runtime

runtime -> rule_version

runtime -> factbook

runtime -> provenance

runtime -> ai

ai -> prompt_version

ai -> model_version

ai -> validation

validation -> audit

audit -> audit_log

audit -> sar_version

audit -> traceability

audit -> security

security -> transport

security -> storage