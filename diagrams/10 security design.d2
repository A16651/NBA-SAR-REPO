    label: "Execution Provenance"
}

####################################################
# AI Governance
####################################################

ai: {
    label: "AI Governance"

    style: {
        fill: "#FDEBD0"
        stroke: "#AF601A"
    }
}

prompt_version: {
    label: "Prompt Versioning"
}

model_version: {
    label: "Model Versioning"
}

